{
  "manifest_version": 3,
  "name": "Bridge Guided Task Mode",
  "description": "Guides users through tasks on the original browser page with model-generated steps.",
  "version": "0.1.0",
  "action": {
    "default_title": "Open Bridge side panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ]
}
