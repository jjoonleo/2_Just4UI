{
  "manifest_version": 3,
  "name": "Bridge Page Snapshot",
  "description": "Extracts a privacy-conscious snapshot of the current page for accessibility simplification research.",
  "version": "0.1.0",
  "action": {
    "default_title": "Extract page snapshot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ]
}
